{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Home Assistant: Start",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/ha.sh",
            "args": [
                "start"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*Home Assistant core started.*$",
                    "endsPattern": "^.*Keyboard interrupt.*$"
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Home Assistant: Stop",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/ha.sh",
            "args": [
                "stop"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Home Assistant: Restart",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/ha.sh",
            "args": [
                "restart"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Home Assistant: Install Dependencies",
            "type": "shell",
            "command": "pip",
            "args": [
                "install",
                "-r",
                "requirements_dev.txt"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Home Assistant: Run Tests",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "pytest",
                "tests/",
                "-v"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                "$pytest"
            ]
        },
        {
            "label": "Home Assistant: Format Code",
            "type": "shell",
            "command": "black",
            "args": [
                "custom_components/",
                "evo-python/",
                "--line-length=119"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Home Assistant: Lint Code",
            "type": "shell",
            "command": "pylint",
            "args": [
                "custom_components/duepi_evo/",
                "evo-python/"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                "$pylint"
            ]
        }
    ]
}
